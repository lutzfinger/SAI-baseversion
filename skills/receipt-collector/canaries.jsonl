{"id": "canary-04-daily-llm-cap-hard-stops", "tier": "extract_receipt_amounts", "fail_mode": "hard_fail", "input": {"today_usd_spend": 4.99, "next_call_estimated_usd": 0.02, "overlay_policy_daily_llm_cap_usd": 5.00}, "expected": {"raises": "BudgetExceeded", "no_api_call_made": true, "audit_log_event": "budget_exceeded", "exit_code": 3, "rationale": "Per SAI #28 (hard ceilings, not queues) the cap MUST fire before the API call, not after."}}
