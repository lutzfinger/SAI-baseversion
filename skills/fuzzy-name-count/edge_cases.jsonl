{"case_id": "edge_three_char_name_exact_only", "input": {"transcript_segments": [{"speaker": "Host", "text": "Ana said something. Anna also did. And andy too."}], "names": ["Ana Vasquez"]}, "expected": {"counts": [1]}, "note": "3-char names require exact match — only literal 'Ana' counts, not 'Anna' or 'and'."}
{"case_id": "edge_typo_caught_above_six_char_threshold", "input": {"transcript_segments": [{"speaker": "Host", "text": "Welcome Michel. Hi Michael."}], "names": ["Michael Smith"]}, "expected": {"counts": [2]}, "note": "Typo 'Michel' (ratio 92) and exact 'Michael' both count — 7-char name uses base threshold 85."}
{"case_id": "edge_typo_blocked_below_short_name_threshold", "input": {"transcript_segments": [{"speaker": "Host", "text": "Welcome Saraa today."}], "names": ["Sarah Smith"]}, "expected": {"counts": [0]}, "note": "Typo 'Saraa' (ratio 80) is blocked for 5-char 'Sarah' which uses threshold 90 — protects short names from common-word collisions."}
{"case_id": "edge_any_speaker_flag", "input": {"transcript_segments": [{"speaker": "Host", "text": "Welcome Sarah."}, {"speaker": "Guest", "text": "Thanks. I am Sarah."}], "names": ["Sarah Smith"], "any_speaker": true}, "expected": {"counts": [2]}, "note": "any_speaker=true counts every speaker's turn."}
{"case_id": "edge_quoted_alias", "input": {"transcript_segments": [{"speaker": "Host", "text": "Mike, your turn. Michael, please."}], "names": ["Michael \"Mike\" Davis"]}, "expected": {"counts": [2]}, "note": "Quoted alias notation also resolves."}
{"case_id": "edge_empty_transcript_segments", "input": {"transcript_segments": [], "names": ["Sarah Smith"]}, "expected": {"counts": [0]}, "note": "Zero segments → zero counts."}
{"case_id": "edge_duplicate_first_name", "input": {"transcript_segments": [{"speaker": "Host", "text": "Sarah, please go ahead."}], "names": ["Sarah Smith", "Sarah Johnson"]}, "expected": {"counts": [1, 1]}, "note": "Two students with same first name both get counted on each mention — known ambiguity, document by alias if it matters."}
