# ───────────────────────────────────────────────────────────────────────
# SAI runtime env — 1Password backend (recommended for shared use)
#
# Copy to ~/.config/sai/runtime.env, fill in your <vault>/<item>/<field>
# paths, then run commands via scripts/with_1password.sh which sets
# OP_SERVICE_ACCOUNT_TOKEN before invoking `op`. Per PRINCIPLES.md §7a:
# `op` MUST run in service-account mode — no biometric prompts.
#
# Bootstrap order matters:
#   1. OP_SERVICE_ACCOUNT_TOKEN itself MUST resolve via keychain://
#      (the only secret that can't be in 1Password — bootstrap problem).
#   2. Everything else uses op:// references.
# ───────────────────────────────────────────────────────────────────────

# Required for the wrapper to talk to 1Password without an unlock dialog.
OP_SERVICE_ACCOUNT_TOKEN="keychain://sai/onepassword_service_account_token"

# Per-operator config (NOT a secret — your real internal email domains).
SAI_INTERNAL_DOMAINS="<your-domain>.com"

# Local file paths (NOT secrets).
SAI_GMAIL_CREDENTIALS_PATH="$HOME/Library/Application Support/SAI/credentials/google_client_secret.json"
SAI_GMAIL_TOKEN_PATH="$HOME/Library/Application Support/SAI/tokens/gmail_token.json"

# Observability switch (NOT a secret).
SAI_LANGSMITH_ENABLED="false"

# ── Vendor LLM keys via 1Password ──
ANTHROPIC_API_KEY="op://<vault>/<item>/<field>"
OPENAI_API_KEY="op://<vault>/<item>/<field>"            # optional; only if you cascade to OpenAI

# ── Slack tokens via 1Password (optional) ──
SAI_SLACK_BOT_TOKEN="op://<vault>/<item>/<field>"
SAI_SLACK_APP_TOKEN="op://<vault>/<item>/<field>"

# ── LangSmith API key (optional) ──
LANGCHAIN_API_KEY="op://<vault>/<item>/<field>"

# How to run any SAI command after this file is in place:
#   bash scripts/with_1password.sh .venv/bin/python -m <module>
