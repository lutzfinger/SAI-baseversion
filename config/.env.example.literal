# ───────────────────────────────────────────────────────────────────────
# SAI runtime env — literal values (LEAST SECURE — last resort)
#
# Copy to ~/.config/sai/runtime.env, paste your real keys in place of
# the placeholder strings. Per PRINCIPLES.md §7, this file MUST NOT be
# committed. The boundary linter rejects any file in the public repo
# with literal sk-/xoxb-/etc. tokens.
#
# Use this only when:
#   - You're on a non-macOS dev box (Keychain unavailable)
#   - You don't have 1Password
#   - This machine never has an extra user account
#
# All three reasons combined still mean: your `runtime.env` becomes
# THE thing protecting your tokens. chmod 600 it. Don't sync it.
# ───────────────────────────────────────────────────────────────────────

# Per-operator config (NOT a secret).
SAI_INTERNAL_DOMAINS="<your-domain>.com"

# Local file paths (NOT secrets).
SAI_GMAIL_CREDENTIALS_PATH="$HOME/Library/Application Support/SAI/credentials/google_client_secret.json"
SAI_GMAIL_TOKEN_PATH="$HOME/Library/Application Support/SAI/tokens/gmail_token.json"

# Observability switch (NOT a secret).
SAI_LANGSMITH_ENABLED="false"

# ── Vendor LLM keys (LITERAL — paste your real values) ──
# WARNING: anyone who reads this file gets your billing.
ANTHROPIC_API_KEY="sk-ant-PUT-YOUR-KEY-HERE"
OPENAI_API_KEY="sk-PUT-YOUR-KEY-HERE"           # optional

# ── Slack tokens (LITERAL — paste your real bot/app tokens) ──
SAI_SLACK_BOT_TOKEN="xoxb-PUT-YOUR-BOT-TOKEN-HERE"
SAI_SLACK_APP_TOKEN="xapp-PUT-YOUR-APP-TOKEN-HERE"

# ── LangSmith (optional) ──
LANGCHAIN_API_KEY="lsv2_pt_PUT-YOUR-KEY-HERE"

# How to run any SAI command after this file is in place:
#   .venv/bin/python -m <module>
# (no wrapper needed; values are read directly)
