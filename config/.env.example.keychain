# ───────────────────────────────────────────────────────────────────────
# SAI runtime env — macOS Keychain backend
#
# Copy to ~/.config/sai/runtime.env. Each keychain:// reference resolves
# via `security find-generic-password -s <service> -a <account>` at
# runtime. Pre-load secrets with:
#
#   security add-generic-password -s sai -a anthropic_api_key \
#       -w 'sk-ant-...' -U
#
# (-U updates if the entry already exists.) Per PRINCIPLES.md §7 secrets
# never live in either repo — only references.
# ───────────────────────────────────────────────────────────────────────

# Per-operator config (NOT a secret).
SAI_INTERNAL_DOMAINS="<your-domain>.com"

# Local file paths (NOT secrets).
SAI_GMAIL_CREDENTIALS_PATH="$HOME/Library/Application Support/SAI/credentials/google_client_secret.json"
SAI_GMAIL_TOKEN_PATH="$HOME/Library/Application Support/SAI/tokens/gmail_token.json"

# Observability switch (NOT a secret).
SAI_LANGSMITH_ENABLED="false"

# ── Vendor LLM keys via macOS Keychain ──
ANTHROPIC_API_KEY="keychain://sai/anthropic_api_key"
OPENAI_API_KEY="keychain://sai/openai_api_key"

# ── Slack tokens via macOS Keychain (optional) ──
SAI_SLACK_BOT_TOKEN="keychain://sai/slack_bot_token"
SAI_SLACK_APP_TOKEN="keychain://sai/slack_app_token"

# ── LangSmith (optional) ──
LANGCHAIN_API_KEY="keychain://sai/langchain_api_key"

# How to run any SAI command after this file is in place:
#   .venv/bin/python -m <module>
# (no wrapper needed; runtime_env.py resolves keychain:// in-process)
