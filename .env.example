SAI_APP_NAME=Secure Agent Infrastructure
SAI_ENVIRONMENT=local
SAI_USER_EMAIL=you@example.com
SAI_ALIAS_EMAIL=sai@example.com
SAI_LOG_LEVEL=INFO
SAI_LOCAL_LLM_ENABLED=true
# Local LLM host — pick one:
# - http://127.0.0.1:11434  (Ollama installed on the host)
# - http://ollama:11434     (docker-compose: Ollama as a sidecar service)
SAI_LOCAL_LLM_HOST=http://127.0.0.1:11434
# qwen2.5:7b is the default — verified reliable for structured output.
# gpt-oss:20b emits empty bodies for many JSON-schema-constrained calls.
SAI_LOCAL_LLM_MODEL=qwen2.5:7b

# Cloud LLM settings. SAI_OPENAI_API_KEY and OPENAI_API_KEY are both accepted.
SAI_OPENAI_API_KEY=
SAI_OPENAI_BASE_URL=

# Optional LangSmith tracing. Leave disabled unless you explicitly want prompt
# and model I/O to be sent to LangSmith for debugging and observability.
SAI_LANGSMITH_ENABLED=false
SAI_LANGSMITH_PROJECT=sai-baseversion
SAI_LANGSMITH_ENDPOINT=
SAI_LANGSMITH_API_KEY=
SAI_LANGSMITH_WORKSPACE_ID=

# Optional Gmail live-run settings
SAI_GMAIL_CREDENTIALS_PATH=
SAI_GMAIL_CLIENT_ID=
SAI_GMAIL_CLIENT_SECRET=
SAI_GMAIL_REFRESH_TOKEN=

# Leave blank to let each workflow keep its own token file under logs/.
SAI_GMAIL_TOKEN_PATH=

# Slack — required for the QA / ask workflows.
#   SAI_SLACK_BOT_TOKEN  (xoxb-…) — chat:write, channels:history, etc.
#   SAI_SLACK_APP_TOKEN  (xapp-…) — connections:write — required for
#                                   slack-bolt Socket Mode (the event-
#                                   driven listener).
SAI_SLACK_BOT_TOKEN=
SAI_SLACK_APP_TOKEN=
SAI_SLACK_EVAL_CHANNEL=sai-eval
SAI_SLACK_ALLOWED_USER_IDS=
SAI_SLACK_SIGNING_SECRET=
