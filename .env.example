SAI_APP_NAME=Secure Agent Infrastructure
SAI_ENVIRONMENT=local
SAI_USER_EMAIL=you@example.com
SAI_LOG_LEVEL=INFO
SAI_GRAPH_CHECKPOINT_PATH=logs/langgraph_checkpoints.sqlite
SAI_LOCAL_LLM_ENABLED=true
SAI_LOCAL_LLM_HOST=http://127.0.0.1:11434
SAI_LOCAL_GUARD_MODEL=llama-guard3:1b
SAI_LOCAL_LLM_MODEL=gpt-oss:20b
SAI_LANGSMITH_ENABLED=false
SAI_LANGSMITH_PROJECT=sai-local
SAI_LANGSMITH_ENDPOINT=
SAI_LANGSMITH_API_KEY=

# Optional Gmail live-run settings
SAI_GMAIL_CREDENTIALS_PATH=
SAI_GMAIL_CLIENT_ID=
SAI_GMAIL_CLIENT_SECRET=
SAI_GMAIL_REFRESH_TOKEN=
SAI_GMAIL_TOKEN_PATH=logs/gmail_token.json
